# Aion2Meter - Client Configuration Sample
# Copy this file to '.env' (in the same directory as the executable) and fill in your details.
# Make sure '.env' is added to your .gitignore to prevent committing secrets.

# The base URL of the AION Stats server (production is https://aion2.cielui.com)
UPLOAD_URL=http://localhost:3001

# The secret API key used to authenticate stats uploads (must match backend's UPLOAD_API_KEY)
UPLOAD_API_KEY=your_secret_api_key_here
